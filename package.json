{
  "name": "agentic-room",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "test": "node scripts/run-tests.mjs",
    "lint": "pnpm -r --if-present lint",
    "db:migrate": "tsx packages/db/src/migrate.ts",
    "db:seed": "tsx packages/db/src/seed.ts",
    "dev:web": "pnpm --filter @agentic-room/web dev",
    "dev:api": "pnpm --filter @agentic-room/api dev",
    "dev:worker": "pnpm --filter @agentic-room/worker dev"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
